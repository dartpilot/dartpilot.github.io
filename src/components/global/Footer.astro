---
import { Icon } from 'astro-icon/components';
import { t, getLocale } from '../../i18n/utils';
import { SITE, NAV_LINKS } from '../../lib/constants';

const locale = getLocale(Astro.url);
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900/50">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-4">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-zinc-900 dark:text-white">
          <Icon name="simple-icons:dart" class="h-6 w-6 text-indigo-500" />
          <span>dartpilot</span>
        </a>
        <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">
          {t('footer.tagline', locale)}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-900 dark:text-white">
          {t('footer.navigation', locale)}
        </h3>
        <ul class="mt-4 space-y-3">
          {NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
              >
                {t(link.label, locale)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-900 dark:text-white">
          {t('footer.resources', locale)}
        </h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/docs/" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">
              Documentation
            </a>
          </li>
          <li>
            <a href="/blog/" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">
              Blog
            </a>
          </li>
          <li>
            <a
              href={SITE.github.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
            >
              GitHub Repository
            </a>
          </li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-900 dark:text-white">
          {t('footer.connect', locale)}
        </h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href={SITE.github.org}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
            >
              <Icon name="simple-icons:github" class="h-4 w-4" />
              GitHub
            </a>
          </li>
          <li>
            <a
              href={SITE.author.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
            >
              <Icon name="lucide:user" class="h-4 w-4" />
              {SITE.author.name}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-zinc-200 pt-8 dark:border-zinc-800 sm:flex-row">
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        {t('footer.copyright', locale, { year: year.toString() })}
      </p>
      <p class="flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400">
        {t('footer.builtWith', locale)}
        <Icon name="lucide:rocket" class="h-4 w-4 text-indigo-500" />
      </p>
    </div>
  </div>
</footer>
