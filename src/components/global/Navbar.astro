---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './ThemeToggle.astro';
import { t, getLocale } from '../../i18n/utils';
import { NAV_LINKS, SITE } from '../../lib/constants';

const locale = getLocale(Astro.url);
const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="fixed top-0 z-50 w-full border-b border-transparent transition-all duration-300"
>
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 text-lg font-bold tracking-tight text-zinc-900 dark:text-white">
      <Icon name="simple-icons:dart" class="h-6 w-6 text-indigo-500" />
      <span>dartpilot</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-1 md:flex">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            currentPath.startsWith(link.href)
              ? 'text-indigo-500 dark:text-indigo-400'
              : 'text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white',
          ]}
        >
          {t(link.label, locale)}
        </a>
      ))}
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-2">
      <a
        href={SITE.github.repo}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg p-2 text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
        aria-label={t('nav.github', locale)}
      >
        <Icon name="simple-icons:github" class="h-5 w-5" />
      </a>
      <ThemeToggle />
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="rounded-lg p-2 text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white md:hidden"
        aria-label={t('nav.toggleMenu', locale)}
        aria-expanded="false"
      >
        <Icon name="lucide:menu" class="h-5 w-5" id="menu-icon-open" />
        <Icon name="lucide:x" class="hidden h-5 w-5" id="menu-icon-close" />
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-zinc-200 bg-white px-6 pb-4 dark:border-zinc-800 dark:bg-zinc-950 md:hidden">
    <div class="flex flex-col gap-1 pt-2">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
            currentPath.startsWith(link.href)
              ? 'bg-indigo-50 text-indigo-500 dark:bg-indigo-950/50 dark:text-indigo-400'
              : 'text-zinc-600 hover:bg-zinc-50 dark:text-zinc-400 dark:hover:bg-zinc-900',
          ]}
        >
          {t(link.label, locale)}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  function initNavbar() {
    const navbar = document.getElementById('navbar');
    const mobileToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    // Scroll glassmorphism
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (navbar) {
        if (scrollY > 20) {
          navbar.classList.add('glass', 'border-zinc-200', 'dark:border-zinc-800');
          navbar.classList.remove('border-transparent');
        } else {
          navbar.classList.remove('glass', 'border-zinc-200', 'dark:border-zinc-800');
          navbar.classList.add('border-transparent');
        }
      }
      lastScroll = scrollY;
    }, { passive: true });

    // Mobile menu toggle
    mobileToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('hidden');
      mobileMenu?.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
      mobileToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  }

  initNavbar();
  document.addEventListener('astro:after-swap', initNavbar);
</script>
