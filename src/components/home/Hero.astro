---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';
import { t, getLocale } from '../../i18n/utils';
import { SITE } from '../../lib/constants';

const locale = getLocale(Astro.url);

const platformIcons = [
  { name: 'lucide:smartphone', label: 'Android' },
  { name: 'lucide:tablet-smartphone', label: 'iOS' },
  { name: 'lucide:globe', label: 'Web' },
  { name: 'lucide:laptop', label: 'macOS' },
  { name: 'lucide:monitor', label: 'Linux' },
  { name: 'lucide:monitor-dot', label: 'Windows' },
];
---

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Gradient Mesh Background -->
  <div class="absolute inset-0 hero-gradient -z-10" />

  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Platform Icons -->
      <div class="mb-8 flex items-center justify-center gap-3">
        {platformIcons.map((p, i) => (
          <div
            class:list={[
              'flex h-10 w-10 items-center justify-center rounded-xl bg-zinc-100 text-zinc-500 dark:bg-zinc-800 dark:text-zinc-400 animate-fade-in-up',
              `delay-${(i + 1) * 100}`,
            ]}
            title={p.label}
          >
            <Icon name={p.name} class="h-5 w-5" />
          </div>
        ))}
      </div>

      <!-- Heading -->
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-6xl lg:text-7xl animate-fade-in-up delay-100">
        {t('hero.title', locale)}
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg text-zinc-600 dark:text-zinc-400 sm:text-xl animate-fade-in-up delay-200">
        {t('hero.subtitle', locale)}
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-fade-in-up delay-300">
        <Button href="/projects/flutter-enterprise-starter/" variant="primary" size="lg">
          <Icon name="lucide:rocket" class="h-5 w-5" />
          {t('hero.cta', locale)}
        </Button>
        <Button href={SITE.github.repo} variant="ghost" size="lg" external>
          <Icon name="simple-icons:github" class="h-5 w-5" />
          {t('hero.github', locale)}
        </Button>
      </div>
    </div>
  </div>
</section>
