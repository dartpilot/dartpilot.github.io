---
import { Icon } from 'astro-icon/components';
import SectionHeading from '../ui/SectionHeading.astro';
import ScrollReveal from '../ui/ScrollReveal.astro';
import { t, getLocale } from '../../i18n/utils';
import { PLATFORMS } from '../../lib/constants';

const locale = getLocale(Astro.url);
---

<section class="py-20 sm:py-28 bg-zinc-50 dark:bg-zinc-900/50">
  <div class="mx-auto max-w-7xl px-6">
    <ScrollReveal>
      <SectionHeading
        title={t('platforms.title', locale)}
        subtitle={t('platforms.subtitle', locale)}
      />
    </ScrollReveal>

    <div class="mx-auto grid max-w-3xl grid-cols-2 gap-4 sm:grid-cols-3">
      {PLATFORMS.map((platform, i) => (
        <ScrollReveal delay={i * 100}>
          <div class="flex flex-col items-center gap-3 rounded-2xl border border-zinc-200 bg-white p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-lg dark:border-zinc-800 dark:bg-zinc-900">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
              <Icon name={platform.icon} class="h-7 w-7" />
            </div>
            <span class="font-medium text-zinc-900 dark:text-white">
              {t(platform.name, locale)}
            </span>
            <Icon name="lucide:check-circle-2" class="h-5 w-5 text-emerald-500" />
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
