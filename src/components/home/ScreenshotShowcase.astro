---
import SectionHeading from '../ui/SectionHeading.astro';
import ScrollReveal from '../ui/ScrollReveal.astro';
import { t, getLocale } from '../../i18n/utils';

const locale = getLocale(Astro.url);

const tabs = [
  { id: 'web-dark', label: 'screenshots.webDark', image: '/images/screenshots/web-login-dark.png' },
  { id: 'web-light', label: 'screenshots.webLight', image: '/images/screenshots/web-login-light.png' },
  { id: 'mobile-login', label: 'screenshots.mobileLogin', image: '/images/screenshots/mobile-login.png' },
  { id: 'mobile-edit', label: 'screenshots.mobileEdit', image: '/images/screenshots/mobile-edit-user.png' },
];
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <ScrollReveal>
      <SectionHeading title={t('screenshots.title', locale)} />
    </ScrollReveal>

    <ScrollReveal>
      <div class="mx-auto max-w-5xl">
        <!-- Tab Buttons -->
        <div class="mb-8 flex flex-wrap items-center justify-center gap-2" role="tablist">
          {tabs.map((tab, i) => (
            <button
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${tab.id}`}
              data-tab={tab.id}
              class:list={[
                'screenshot-tab rounded-lg px-4 py-2 text-sm font-medium transition-all',
                i === 0
                  ? 'bg-indigo-500 text-white'
                  : 'bg-zinc-100 text-zinc-600 hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-700',
              ]}
            >
              {t(tab.label, locale)}
            </button>
          ))}
        </div>

        <!-- Tab Panels -->
        <div class="relative">
          {tabs.map((tab, i) => (
            <div
              id={`panel-${tab.id}`}
              role="tabpanel"
              class:list={['screenshot-panel', i !== 0 && 'hidden']}
              data-tab={tab.id}
            >
              <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-2xl dark:border-zinc-700 dark:bg-zinc-800">
                <!-- Browser Frame -->
                <div class="flex items-center gap-2 border-b border-zinc-200 bg-zinc-50 px-4 py-3 dark:border-zinc-700 dark:bg-zinc-900">
                  <div class="flex gap-1.5">
                    <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-600" />
                    <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-600" />
                    <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-600" />
                  </div>
                  <div class="mx-4 flex-1 rounded-md bg-zinc-200 px-3 py-1 text-xs text-zinc-500 dark:bg-zinc-800 dark:text-zinc-400">
                    dartpilot.dev
                  </div>
                </div>
                <img
                  src={tab.image}
                  alt={t(tab.label, locale)}
                  class="w-full"
                  loading="lazy"
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<script>
  function initScreenshotTabs() {
    const tabs = document.querySelectorAll('.screenshot-tab');
    const panels = document.querySelectorAll('.screenshot-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;

        // Update tabs
        tabs.forEach((t) => {
          t.classList.remove('bg-indigo-500', 'text-white');
          t.classList.add('bg-zinc-100', 'text-zinc-600', 'dark:bg-zinc-800', 'dark:text-zinc-400');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.remove('bg-zinc-100', 'text-zinc-600', 'dark:bg-zinc-800', 'dark:text-zinc-400');
        tab.classList.add('bg-indigo-500', 'text-white');
        tab.setAttribute('aria-selected', 'true');

        // Update panels
        panels.forEach((p) => {
          if ((p as HTMLElement).dataset.tab === target) {
            p.classList.remove('hidden');
          } else {
            p.classList.add('hidden');
          }
        });
      });
    });
  }

  initScreenshotTabs();
  document.addEventListener('astro:after-swap', initScreenshotTabs);
</script>
