---
import { Icon } from 'astro-icon/components';
import ScrollReveal from '../ui/ScrollReveal.astro';
import { t, getLocale } from '../../i18n/utils';
import { STATS } from '../../lib/constants';

const locale = getLocale(Astro.url);

const statIcons = [
  'lucide:check-circle',
  'lucide:layers',
  'lucide:component',
  'lucide:shield-check',
];
---

<ScrollReveal>
  <section class="relative py-6">
    <div class="mx-auto max-w-5xl px-6">
      <div class="glass rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6">
        <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
          {STATS.map((stat, i) => (
            <div class="flex items-center gap-3 justify-center">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-indigo-500 dark:bg-indigo-950/50 dark:text-indigo-400">
                <Icon name={statIcons[i]} class="h-5 w-5" />
              </div>
              <div>
                <div class="text-2xl font-bold text-zinc-900 dark:text-white">
                  {stat.display || `${stat.value}${stat.suffix}`}
                </div>
                <div class="text-sm text-zinc-500 dark:text-zinc-400">
                  {t(stat.label, locale)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</ScrollReveal>
