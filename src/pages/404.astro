---
import { Icon } from 'astro-icon/components';
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import { t, getLocale } from '../i18n/utils';

const locale = getLocale(Astro.url);
---

<PageLayout title="Page Not Found — dartpilot">
  <section class="flex min-h-[70vh] items-center justify-center px-6">
    <div class="text-center">
      <div class="mb-6 inline-flex h-20 w-20 items-center justify-center rounded-2xl bg-zinc-100 dark:bg-zinc-800">
        <Icon name="lucide:search-x" class="h-10 w-10 text-zinc-400" />
      </div>
      <h1 class="text-6xl font-bold text-zinc-900 dark:text-white">404</h1>
      <h2 class="mt-4 text-xl font-semibold text-zinc-700 dark:text-zinc-300">
        {t('notFound.title', locale)}
      </h2>
      <p class="mt-2 text-zinc-500 dark:text-zinc-400 max-w-md mx-auto">
        {t('notFound.description', locale)}
      </p>
      <div class="mt-8">
        <Button href="/" variant="primary">
          <Icon name="lucide:home" class="h-4 w-4" />
          {t('notFound.cta', locale)}
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
