---
import { Icon } from 'astro-icon/components';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Card from '../components/ui/Card.astro';
import ScrollReveal from '../components/ui/ScrollReveal.astro';
import { t, getLocale } from '../i18n/utils';
import { SITE } from '../lib/constants';

const locale = getLocale(Astro.url);

const milestones = [
  { date: '2024', title: 'Project Started', description: 'First commit of flutter_bloc_advance template.' },
  { date: '2025 Q1', title: 'BLoC Pattern Established', description: 'Complete BLoC + Repository pattern with state management.' },
  { date: '2025 Q3', title: '6-Platform Support', description: 'Android, iOS, Web, macOS, Linux, Windows — all from one codebase.' },
  { date: '2026 Q1', title: 'Feature-First Migration', description: 'Full architectural migration to feature-first clean boundaries with 472+ tests.' },
  { date: '2026 Q1', title: 'Design System & UI Overhaul', description: '14+ reusable components, responsive shell, command palette, accessibility.' },
  { date: '2026 Q1', title: 'dartpilot Organization', description: 'Community-focused organization launched with dartpilot.dev.' },
];
---

<PageLayout title="About — dartpilot" description="Learn about the dartpilot organization and its mission to accelerate Flutter development.">
  <!-- Hero -->
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-5xl">
            {t('about.title', locale)}
          </h1>
          <p class="mt-6 text-lg text-zinc-600 dark:text-zinc-400">
            {t('about.mission', locale)}
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Author -->
  <section class="py-16 bg-zinc-50 dark:bg-zinc-900/50">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-3xl">
          <Card padding="lg" hover={false}>
            <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:text-left">
              <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-indigo-100 dark:bg-indigo-950/50">
                <Icon name="lucide:user" class="h-10 w-10 text-indigo-500" />
              </div>
              <div>
                <h2 class="text-sm font-medium uppercase tracking-wider text-indigo-500">
                  {t('about.author', locale)}
                </h2>
                <h3 class="mt-1 text-xl font-bold text-zinc-900 dark:text-white">
                  {t('about.authorName', locale)}
                </h3>
                <p class="mt-2 text-zinc-600 dark:text-zinc-400">
                  {t('about.authorBio', locale)}
                </p>
                <a
                  href={SITE.author.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-3 inline-flex items-center gap-2 text-sm font-medium text-indigo-500 hover:text-indigo-600"
                >
                  <Icon name="simple-icons:github" class="h-4 w-4" />
                  GitHub Profile
                </a>
              </div>
            </div>
          </Card>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-3xl">
          <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-8 text-center">
            Project Timeline
          </h2>
          <div class="relative">
            <!-- Vertical line -->
            <div class="absolute left-4 top-0 bottom-0 w-px bg-zinc-200 dark:bg-zinc-700 sm:left-1/2 sm:-translate-x-px" />

            <div class="space-y-8">
              {milestones.map((milestone, i) => (
                <ScrollReveal delay={i * 100}>
                  <div class:list={[
                    'relative flex items-start gap-6',
                    i % 2 === 0 ? 'sm:flex-row' : 'sm:flex-row-reverse',
                  ]}>
                    <!-- Dot -->
                    <div class="absolute left-4 -translate-x-1/2 sm:left-1/2">
                      <div class="h-3 w-3 rounded-full border-2 border-indigo-500 bg-white dark:bg-zinc-950" />
                    </div>

                    <!-- Content -->
                    <div class:list={[
                      'ml-10 sm:ml-0 sm:w-1/2',
                      i % 2 === 0 ? 'sm:pr-12 sm:text-right' : 'sm:pl-12',
                    ]}>
                      <span class="text-sm font-medium text-indigo-500">{milestone.date}</span>
                      <h3 class="mt-1 font-bold text-zinc-900 dark:text-white">{milestone.title}</h3>
                      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{milestone.description}</p>
                    </div>
                  </div>
                </ScrollReveal>
              ))}
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</PageLayout>
