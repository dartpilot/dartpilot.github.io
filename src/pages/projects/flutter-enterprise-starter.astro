---
import { Icon } from 'astro-icon/components';
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';
import ScrollReveal from '../../components/ui/ScrollReveal.astro';
import { t, getLocale } from '../../i18n/utils';
import { projects } from '../../data/projects';

const locale = getLocale(Astro.url);
const project = projects[0];

const screenshots = [
  { src: '/images/screenshots/web-login-dark.png', alt: 'Web Login Dark' },
  { src: '/images/screenshots/web-login-light.png', alt: 'Web Login Light' },
  { src: '/images/screenshots/web-list-user.png', alt: 'Web User List' },
  { src: '/images/screenshots/mobile-login.png', alt: 'Mobile Login' },
  { src: '/images/screenshots/mobile-edit-user.png', alt: 'Mobile Edit User' },
];

const quickStartSteps = [
  { cmd: 'git clone https://github.com/dartpilot/flutter-enterprise-starter.git', desc: 'Clone the repository' },
  { cmd: 'cd flutter-enterprise-starter', desc: 'Enter the project directory' },
  { cmd: 'fvm use', desc: 'Set Flutter version' },
  { cmd: 'fvm flutter pub get', desc: 'Install dependencies' },
  { cmd: 'fvm flutter run --target lib/main/main_local.dart', desc: 'Run with mock data' },
];
---

<PageLayout
  title={`${project.name} — dartpilot`}
  description={project.description}
>
  <!-- Hero -->
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-4xl">
          <div class="flex items-center gap-3 mb-4">
            <Icon name="simple-icons:flutter" class="h-10 w-10 text-indigo-500" />
            <span class="text-sm font-medium text-indigo-500">Open Source</span>
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-5xl">
            {project.name}
          </h1>
          <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400 max-w-3xl">
            {project.longDescription}
          </p>

          <!-- Actions -->
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href={project.github} variant="primary" size="lg" external>
              <Icon name="simple-icons:github" class="h-5 w-5" />
              View on GitHub
            </Button>
            {project.deepwiki && (
              <Button href={project.deepwiki} variant="ghost" size="lg" external>
                <Icon name="lucide:book-open" class="h-5 w-5" />
                DeepWiki
              </Button>
            )}
          </div>

          <!-- Stats -->
          <div class="mt-8 flex flex-wrap gap-8">
            {project.stats.map((stat) => (
              <div>
                <div class="text-2xl font-bold text-zinc-900 dark:text-white">{stat.value}</div>
                <div class="text-sm text-zinc-500 dark:text-zinc-400">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-16 bg-zinc-50 dark:bg-zinc-900/50">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-4xl">
          <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-6">
            {t('projectDetail.techStack', locale)}
          </h2>
          <div class="flex flex-wrap gap-3">
            {project.techStack.map((tech) => (
              <div class="flex items-center gap-2 rounded-xl border border-zinc-200 bg-white px-4 py-3 dark:border-zinc-700 dark:bg-zinc-800">
                {tech.icon && <Icon name={tech.icon} class="h-5 w-5 text-indigo-500" />}
                <span class="font-medium text-zinc-900 dark:text-white">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-4xl">
          <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-6">Features</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {project.features.map((feature) => (
              <div class="flex items-start gap-3 rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900">
                <Icon name="lucide:check-circle-2" class="mt-0.5 h-5 w-5 shrink-0 text-emerald-500" />
                <span class="text-zinc-700 dark:text-zinc-300">{feature}</span>
              </div>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Architecture -->
  <section class="py-16 bg-zinc-50 dark:bg-zinc-900/50">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-4xl">
          <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-6">
            {t('projectDetail.architecture', locale)}
          </h2>
          <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white p-4 dark:border-zinc-700 dark:bg-zinc-800">
            <img
              src="/images/architecture/high-level-architecture.svg"
              alt="High-Level Architecture"
              class="w-full dark:invert dark:brightness-90"
            />
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-4xl">
          <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-6">
            {t('projectDetail.screenshots', locale)}
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {screenshots.map((screenshot) => (
              <div class="overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-700">
                <img
                  src={screenshot.src}
                  alt={screenshot.alt}
                  class="w-full"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="py-16 bg-zinc-50 dark:bg-zinc-900/50">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <div class="mx-auto max-w-4xl">
          <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-6">
            {t('projectDetail.quickStart', locale)}
          </h2>
          <div class="overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-700">
            <div class="flex items-center gap-2 border-b border-zinc-200 bg-zinc-50 px-4 py-3 dark:border-zinc-700 dark:bg-zinc-900">
              <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-red-400" />
                <div class="h-3 w-3 rounded-full bg-yellow-400" />
                <div class="h-3 w-3 rounded-full bg-green-400" />
              </div>
              <span class="ml-2 text-xs text-zinc-500 dark:text-zinc-400">Terminal</span>
            </div>
            <div class="bg-zinc-900 p-6 font-mono text-sm space-y-3">
              {quickStartSteps.map((step) => (
                <div>
                  <div class="text-zinc-500 text-xs mb-1"># {step.desc}</div>
                  <div class="flex items-start gap-2">
                    <span class="select-none text-indigo-400">$</span>
                    <span class="text-zinc-300">{step.cmd}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</PageLayout>
