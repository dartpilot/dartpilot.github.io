---
import { Icon } from 'astro-icon/components';
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import ScrollReveal from '../../components/ui/ScrollReveal.astro';
import { t, getLocale } from '../../i18n/utils';
import { projects } from '../../data/projects';

const locale = getLocale(Astro.url);
---

<PageLayout title="Projects — dartpilot" description="Open-source tools and templates for the Flutter/Dart ecosystem.">
  <section class="pt-32 pb-20">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal>
        <SectionHeading
          title={t('projects.title', locale)}
          subtitle={t('projects.subtitle', locale)}
        />
      </ScrollReveal>

      <div class="mx-auto max-w-4xl space-y-8">
        {projects.map((project, i) => (
          <ScrollReveal delay={i * 100}>
            <Card padding="lg" class="group">
              <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:gap-8">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    <Icon name="simple-icons:flutter" class="h-8 w-8 text-indigo-500" />
                    <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">
                      {project.name}
                    </h2>
                  </div>
                  <p class="text-zinc-600 dark:text-zinc-400">
                    {project.description}
                  </p>

                  <!-- Tech badges -->
                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.techStack.map((tech) => (
                      <Badge>
                        {tech.icon && <Icon name={tech.icon} class="h-3.5 w-3.5" />}
                        {tech.name}
                      </Badge>
                    ))}
                  </div>

                  <!-- Stats -->
                  <div class="mt-6 flex flex-wrap gap-6">
                    {project.stats.map((stat) => (
                      <div class="text-center">
                        <div class="text-xl font-bold text-zinc-900 dark:text-white">{stat.value}</div>
                        <div class="text-xs text-zinc-500 dark:text-zinc-400">{stat.label}</div>
                      </div>
                    ))}
                  </div>

                  <!-- Actions -->
                  <div class="mt-6 flex flex-wrap gap-3">
                    <Button href={`/projects/${project.slug}/`} variant="primary" size="sm">
                      {t('projects.viewProject', locale)}
                    </Button>
                    <Button href={project.github} variant="ghost" size="sm" external>
                      <Icon name="simple-icons:github" class="h-4 w-4" />
                      {t('projects.viewOnGithub', locale)}
                    </Button>
                  </div>
                </div>
              </div>
            </Card>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
